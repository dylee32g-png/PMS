          const prevMonthSuffix = parseInt(targetMonths.prevMonthStr.split('-')[1], 10) + '월';

          Object.keys(p).forEach(k => {
              if (k.startsWith('dyn_')) {
                  hasDyn = true;
                  const val = safeNumber(p[k]);
                  dynSum += val;
                  if (k.endsWith(currMonthSuffix)) currPointsVal += val;
                  if (k.endsWith(prevMonthSuffix)) prevPointsVal += val;
              }
          });

          if (hasDyn) {
              accPointsVal = dynSum;
          } else {
              accPointsVal = safeNumber(p.accPoints);
              currPointsVal = safeNumber(p.currPoints);
              prevPointsVal = safeNumber(p.prevPoints);
          }
      }
